generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  Admin
  Manager
  Sales
  Operations
  Viewer
}

enum LeadTemperature {
  Hot
  Warm
  Cold
  FollowUpLater
}

enum LeadStatus {
  New
  Qualified
  Visit
  FollowUp
  Negotiation
  Won
  Lost
  OnHold
  Recycle
}

enum PropertyType {
  Residential
  Commercial
  Plot
  Villa
  Apartment
  Office
}

enum Purpose {
  EndUse
  Investment
}

enum OpportunityStatus {
  Active
  Inactive
  Sold
}

enum TaskPriority {
  Low
  Medium
  High
  Critical
}

enum TaskStatus {
  Todo
  InProgress
  Done
  Cancelled
}

enum RecurrenceType {
  None
  Daily
  Weekly
  Monthly
}

enum LostReason {
  Budget
  Location
  Configuration
  Timing
  NotSerious
  Financing
  PurchasedElsewhere
  Other
}

enum FollowUpType {
  Call
  Email
  WhatsApp
  Visit
  Meeting
  Activity
  Internal
}

enum FollowUpPriority {
  High
  Medium
  Low
}

enum EntityType {
  Lead
  Opportunity
  Task
  User
}

enum NotificationType {
  LeadAssigned
  TaskAssigned
  FollowUpDue
  FollowUpOverdue
  TaskOverdue
  HotLeadStale
  StageChanged
  NoteAdded
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  name          String
  short_name    String   @default("")
  email         String   @unique
  password_hash String
  role          UserRole @default(Sales)
  is_active     Boolean  @default(true)
  avatar_url    String?
  phone         String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  leads_owned          Lead[]               @relation("LeadOwner")
  leads_assigned       Lead[]               @relation("LeadAssignee")
  leads_created        Lead[]               @relation("LeadCreator")
  tasks_assigned       Task[]               @relation("TaskAssignee")
  tasks_created        Task[]               @relation("TaskCreator")
  opps_created         Opportunity[]        @relation("OppCreator")
  activities           Activity[]
  notes                Note[]
  attachments          Attachment[]
  notifications        Notification[]
  followups_created    FollowUp[]  @relation("FollowUpCreator")
  followups_assigned   FollowUp[]  @relation("FollowUpAssignee")
  stage_changes        LeadStageHistory[]
  lead_opp_tags        LeadOpportunity[]
  expenses_added       OpportunityExpense[]
  password_reset_tokens PasswordResetToken[]

  commission_slabs         SalesCommissionSlab[]   @relation("CommissionSlabs")
  commission_slabs_created SalesCommissionSlab[]   @relation("SlabsCreatedBy")
  monthly_targets          SalesMonthlyTarget[]    @relation("MonthlyTargets")
  monthly_targets_set      SalesMonthlyTarget[]    @relation("TargetsSetBy")
  commission_records       SalesCommissionRecord[] @relation("CommissionRecords")
  commission_records_final SalesCommissionRecord[] @relation("RecordsFinalized")

  @@map("users")
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  token      String   @unique
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  expires_at DateTime
  created_at DateTime @default(now())

  @@index([user_id])
  @@map("password_reset_tokens")
}

// ─────────────────────────────────────────────
// LEAD
// ─────────────────────────────────────────────

model Lead {
  id          String @id @default(cuid())
  lead_number String @unique

  // MVP Mandatory
  full_name   String
  phone       String
  email       String?
  whatsapp    String?
  lead_source String
  temperature LeadTemperature @default(Cold)
  status      LeadStatus      @default(New)

  // Standard
  campaign_source     String?
  referral_source     String?
  budget_min          Decimal?      @db.Decimal(12, 2)
  budget_max          Decimal?      @db.Decimal(12, 2)
  property_type       PropertyType?
  unit_type           String?
  location_preference String?
  timeline_to_buy     String?
  purpose             Purpose?
  first_contact_date  DateTime?
  last_contact_date   DateTime?
  next_followup_date  DateTime?
  followup_type       FollowUpType?
  outcome             String?
  reason_for_interest String?
  visit_status        String?
  negotiation_status  String?
  closing_probability Int?
  deal_value          Decimal?      @db.Decimal(12, 2)
  commission_estimate Decimal?      @db.Decimal(12, 2)

  // Financial
  potential_lead_value    Decimal? @db.Decimal(12, 2)
  financing_required      Boolean?
  // Won deal fields
  settlement_value        Decimal? @db.Decimal(12, 2)
  deal_commission_percent Decimal? @db.Decimal(8, 4)

  // Advanced
  reason_not_interested String?
  alternate_requirement String?
  lost_reason           LostReason?
  lost_notes            String?

  // Soft delete
  deleted_at DateTime?
  deleted_by String?

  // FKs
  lead_owner_id  String
  assigned_to_id String
  created_by_id  String

  lead_owner  User @relation("LeadOwner",   fields: [lead_owner_id],  references: [id])
  assigned_to User @relation("LeadAssignee", fields: [assigned_to_id], references: [id])
  created_by  User @relation("LeadCreator",  fields: [created_by_id],  references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  opportunities LeadOpportunity[]
  tasks         Task[]
  stage_history LeadStageHistory[]
  followups     FollowUp[]

  @@index([phone])
  @@index([email])
  @@index([status])
  @@index([temperature])
  @@index([assigned_to_id])
  @@index([next_followup_date])
  @@index([deleted_at])
  @@map("leads")
}

// ─────────────────────────────────────────────
// OPPORTUNITY
// ─────────────────────────────────────────────

model Opportunity {
  id                String            @id @default(cuid())
  opp_number        String            @unique
  name              String
  project           String
  developer         String?
  property_type     PropertyType
  location          String
  commission_percent Decimal          @db.Decimal(8, 4)
  status            OpportunityStatus @default(Active)
  notes             String?

  // Financial (auto-calculated from configurations)
  total_sales_value Decimal? @db.Decimal(14, 2)
  possible_revenue  Decimal? @db.Decimal(14, 2)
  closed_revenue    Decimal? @db.Decimal(14, 2)

  deleted_at    DateTime?
  created_by_id String
  created_by    User              @relation("OppCreator", fields: [created_by_id], references: [id])
  created_at    DateTime          @default(now())
  updated_at    DateTime          @updatedAt

  configurations OpportunityConfiguration[]
  leads          LeadOpportunity[]
  tasks          Task[]
  expenses       OpportunityExpense[]
  follow_ups     FollowUp[]

  @@index([status])
  @@index([property_type])
  @@map("opportunities")
}

// ─────────────────────────────────────────────
// OPPORTUNITY CONFIGURATION (inventory rows)
// ─────────────────────────────────────────────

model OpportunityConfiguration {
  id              String   @id @default(cuid())
  opportunity_id  String
  label           String
  number_of_units Int
  price_per_unit  Decimal  @db.Decimal(12, 2)
  row_total       Decimal  @db.Decimal(14, 2)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  opportunity Opportunity @relation(fields: [opportunity_id], references: [id])

  @@index([opportunity_id])
  @@map("opportunity_configurations")
}

// ─────────────────────────────────────────────
// OPPORTUNITY EXPENSE
// ─────────────────────────────────────────────

model OpportunityExpense {
  id             String      @id @default(cuid())
  opportunity_id String
  expense_date   DateTime    @default(now())
  category       String
  description    String?
  amount         Decimal     @db.Decimal(12, 2)
  added_by_id    String
  created_at     DateTime    @default(now())

  opportunity Opportunity @relation(fields: [opportunity_id], references: [id])
  added_by    User        @relation(fields: [added_by_id], references: [id])

  @@index([opportunity_id])
  @@map("opportunity_expenses")
}

// ─────────────────────────────────────────────
// JUNCTION: Lead <-> Opportunity
// ─────────────────────────────────────────────

model LeadOpportunity {
  id                String   @id @default(cuid())
  lead_id           String
  opportunity_id    String
  tagged_at         DateTime @default(now())
  tagged_by_id      String
  smart_match_score Int?
  notes             String?

  lead        Lead        @relation(fields: [lead_id],        references: [id])
  opportunity Opportunity @relation(fields: [opportunity_id], references: [id])
  tagged_by   User        @relation(fields: [tagged_by_id],   references: [id])

  @@unique([lead_id, opportunity_id])
  @@map("lead_opportunities")
}

// ─────────────────────────────────────────────
// CLIENT
// ─────────────────────────────────────────────

model Client {
  id              String   @id @default(cuid())
  name            String
  industry        String?
  contact_person  String?
  contact_email   String?
  contact_phone   String?
  notes           String?
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  tasks Task[]

  @@index([is_active])
  @@map("clients")
}

// ─────────────────────────────────────────────
// TASK
// ─────────────────────────────────────────────

model Task {
  id              String         @id @default(cuid())
  task_number     String         @unique
  title           String
  description     String?
  priority        TaskPriority   @default(Medium)
  status          TaskStatus     @default(Todo)
  due_date        DateTime
  start_date      DateTime?
  completion_date DateTime?
  sector          String?
  revenue_tagged  Boolean        @default(false)
  revenue_amount  Decimal?       @db.Decimal(12, 2)
  notes           String?
  checklist       Json?
  recurrence      RecurrenceType @default(None)
  deleted_at      DateTime?

  assigned_to_id String
  created_by_id  String
  lead_id        String?
  opportunity_id String?
  client_id      String?

  assigned_to User         @relation("TaskAssignee", fields: [assigned_to_id], references: [id])
  created_by  User         @relation("TaskCreator",  fields: [created_by_id],  references: [id])
  lead        Lead?        @relation(fields: [lead_id],        references: [id])
  opportunity Opportunity? @relation(fields: [opportunity_id], references: [id])
  client      Client?      @relation(fields: [client_id],      references: [id])
  followups   FollowUp[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([assigned_to_id])
  @@index([status])
  @@index([due_date])
  @@index([lead_id])
  @@index([opportunity_id])
  @@index([client_id])
  @@index([deleted_at])
  @@map("tasks")
}

// ─────────────────────────────────────────────
// LEAD STAGE HISTORY
// ─────────────────────────────────────────────

model LeadStageHistory {
  id            String      @id @default(cuid())
  lead_id       String
  from_stage    LeadStatus?
  to_stage      LeadStatus
  changed_by_id String
  changed_at    DateTime    @default(now())
  notes         String?

  lead       Lead @relation(fields: [lead_id],       references: [id])
  changed_by User @relation(fields: [changed_by_id], references: [id])

  @@index([lead_id])
  @@map("lead_stage_history")
}

// ─────────────────────────────────────────────
// ACTIVITY (Unified Timeline — no polymorphic FKs)
// ─────────────────────────────────────────────

model Activity {
  id          String     @id @default(cuid())
  entity_type EntityType
  entity_id   String
  action      String
  actor_id    String
  metadata    Json?
  created_at  DateTime   @default(now())

  actor User @relation(fields: [actor_id], references: [id])

  @@index([entity_type, entity_id])
  @@index([created_at])
  @@map("activities")
}

// ─────────────────────────────────────────────
// NOTE (no polymorphic FKs)
// ─────────────────────────────────────────────

model Note {
  id            String     @id @default(cuid())
  entity_type   EntityType
  entity_id     String
  content       String     @db.Text
  created_by_id String
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  created_by User @relation(fields: [created_by_id], references: [id])

  @@index([entity_type, entity_id])
  @@map("notes")
}

// ─────────────────────────────────────────────
// ATTACHMENT (no polymorphic FKs)
// ─────────────────────────────────────────────

model Attachment {
  id             String     @id @default(cuid())
  entity_type    EntityType
  entity_id      String
  file_url       String
  file_name      String
  file_size      Int
  file_type      String?
  uploaded_by_id String
  created_at     DateTime   @default(now())

  uploaded_by User @relation(fields: [uploaded_by_id], references: [id])

  @@index([entity_type, entity_id])
  @@map("attachments")
}

// ─────────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────────

model Notification {
  id          String           @id @default(cuid())
  user_id     String
  type        NotificationType
  message     String
  entity_type EntityType?
  entity_id   String?
  read        Boolean          @default(false)
  created_at  DateTime         @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id, read])
  @@index([created_at])
  @@map("notifications")
}

// ─────────────────────────────────────────────
// FOLLOW UP
// ─────────────────────────────────────────────

model FollowUp {
  id             String           @id @default(cuid())
  lead_id        String?
  opportunity_id String?
  task_id        String?
  assigned_to_id String?
  type           FollowUpType
  priority       FollowUpPriority @default(Medium)
  scheduled_at   DateTime
  completed_at   DateTime?
  notes          String?
  outcome        String?
  created_by_id  String
  created_at     DateTime         @default(now())
  updated_at     DateTime         @default(now()) @updatedAt

  lead        Lead?        @relation(fields: [lead_id],        references: [id])
  opportunity Opportunity? @relation(fields: [opportunity_id], references: [id])
  task        Task?        @relation(fields: [task_id],        references: [id])
  assigned_to User?        @relation("FollowUpAssignee", fields: [assigned_to_id], references: [id])
  created_by  User         @relation("FollowUpCreator",  fields: [created_by_id],  references: [id])

  @@index([lead_id])
  @@index([opportunity_id])
  @@index([task_id])
  @@index([assigned_to_id])
  @@index([scheduled_at])
  @@index([completed_at])
  @@map("follow_ups")
}

// ─────────────────────────────────────────────
// SEQUENCE COUNTERS (for auto IDs)
// ─────────────────────────────────────────────

model SequenceCounter {
  entity   String @id
  last_val Int    @default(0)

  @@map("sequence_counters")
}

// ─────────────────────────────────────────────
// SALES COMMISSION
// ─────────────────────────────────────────────

enum CommissionRecStatus {
  Live
  Finalized
}

model SalesCommissionSlab {
  id             String   @id @default(cuid())
  structure_id   String   // UUID grouping all slabs saved in one batch
  user_id        String
  effective_from DateTime @db.Date
  from_amount    Decimal  @db.Decimal(14, 2)
  to_amount      Decimal? @db.Decimal(14, 2) // null = uncapped top slab
  commission_pct Decimal  @db.Decimal(6, 4)
  sort_order     Int
  created_by_id  String
  created_at     DateTime @default(now())

  user       User @relation("CommissionSlabs",   fields: [user_id],       references: [id])
  created_by User @relation("SlabsCreatedBy",    fields: [created_by_id], references: [id])

  @@index([user_id, effective_from])
  @@index([structure_id])
  @@map("sales_commission_slabs")
}

model SalesMonthlyTarget {
  id            String   @id @default(cuid())
  user_id       String
  year          Int
  month         Int      // 1–12
  target_amount Decimal  @db.Decimal(14, 2)
  set_by_id     String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  user   User @relation("MonthlyTargets", fields: [user_id],  references: [id])
  set_by User @relation("TargetsSetBy",   fields: [set_by_id], references: [id])

  @@unique([user_id, year, month])
  @@index([user_id])
  @@map("sales_monthly_targets")
}

model SalesCommissionRecord {
  id                  String              @id @default(cuid())
  user_id             String
  year                Int
  month               Int
  closed_revenue      Decimal             @db.Decimal(14, 2)
  leads_won           Int                 @default(0)
  leads_won_no_value  Int                 @default(0)
  target_amount       Decimal?            @db.Decimal(14, 2)
  achievement_pct     Decimal?            @db.Decimal(8, 4)
  slab_from           Decimal?            @db.Decimal(14, 2)
  slab_to             Decimal?            @db.Decimal(14, 2)
  slab_pct            Decimal?            @db.Decimal(6, 4)
  commission_amount   Decimal?            @db.Decimal(14, 2)
  rec_status          CommissionRecStatus @default(Live)
  finalized_at        DateTime?
  finalized_by_id     String?
  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt

  user         User  @relation("CommissionRecords",  fields: [user_id],         references: [id])
  finalized_by User? @relation("RecordsFinalized",   fields: [finalized_by_id], references: [id])

  @@unique([user_id, year, month])
  @@index([user_id])
  @@index([year, month])
  @@map("sales_commission_records")
}

// ─────────────────────────────────────────────
// PODCAST STUDIO (standalone, no CRM relations)
// ─────────────────────────────────────────────

enum PodcastBookingStatus {
  Confirmed
  Tentative
  Cancelled
  Completed
}

model PodcastStudioBooking {
  id               String               @id @default(cuid())
  booking_date     String               // "YYYY-MM-DD" — stored as ISO date string, IST-safe
  start_time       String               // "HH:MM" e.g. "14:00"
  end_time         String               // "HH:MM" auto-calculated
  duration_minutes Int
  booking_type     String               @default("One-time") // "One-time" | "Recurring"
  seater_type      String?              // "1-Seater" | "2-Seater" | "3-Seater" | "4-Seater"
  client_name      String
  phone            String?
  notes            String?
  recording_hours  Decimal?             @db.Decimal(8, 2)
  recording_value  Decimal?             @db.Decimal(12, 2)
  editing_hours    Decimal?             @db.Decimal(8, 2)
  editing_value    Decimal?             @db.Decimal(12, 2)
  gst_percent      Decimal              @default(18.00) @db.Decimal(5, 2)
  base_amount      Decimal              @default(0) @db.Decimal(12, 2)
  gst_amount       Decimal              @default(0) @db.Decimal(12, 2)
  total_revenue    Decimal              @default(0) @db.Decimal(12, 2)
  status               PodcastBookingStatus @default(Confirmed)
  recurring_group_id   String?              // links bookings created together as a recurring series
  created_at           DateTime             @default(now())
  updated_at           DateTime             @updatedAt

  @@index([booking_date])
  @@index([status])
  @@index([client_name])
  @@index([recurring_group_id])
  @@map("podcast_studio_bookings")
}

// Per-seater pricing rates — configurable by Admin
model PodcastStudioRate {
  id                      String   @id @default(cuid())
  seater_type             String   @unique // "1-Seater" | "2-Seater" | "3-Seater" | "4-Seater"
  recording_rate_per_hour Decimal  @default(0) @db.Decimal(10, 2)
  editing_rate_per_hour   Decimal  @default(0) @db.Decimal(10, 2)
  updated_at              DateTime @updatedAt

  @@map("podcast_studio_rates")
}

// IntentRadar Module - Prisma Schema
// Add these models to your existing schema.prisma file
// All tables are prefixed with "ir_" to avoid conflicts with your CRM

// ─── SETTINGS ───
model ir_settings {
  id         String   @id @default(cuid())
  key        String   @unique
  value      String   @db.Text
  category   String   // 'api_keys' | 'scraping' | 'scoring' | 'ai'
  encrypted  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── SEARCH CAMPAIGNS ───
model ir_campaign {
  id             String   @id @default(cuid())
  name           String
  status         String   @default("draft") // draft | running | completed | failed
  
  // Input criteria
  city           String
  microMarkets   String[] // e.g., ["Indiranagar", "Koramangala", "HSR Layout"]
  budgetMin      Float    // in Cr
  budgetMax      Float
  propertyType   String   // apartment | villa | plot | commercial
  bhkConfig      String?  // 2BHK | 3BHK | 4BHK
  buyerPersonas  String[] // end_user | nri | investor | upgrade_buyer | first_time
  urgency        String   // immediate | 6_months | exploring
  
  // Sources to scan
  sources        String[] // youtube | reddit | telegram | instagram | 99acres | magicbricks | etc
  
  // Custom keywords
  keywords       String[]
  
  // Results
  totalLeads     Int      @default(0)
  hotLeads       Int      @default(0)
  warmLeads      Int      @default(0)
  coolLeads      Int      @default(0)
  
  // Intent mode — drives entire pipeline behaviour
  intentMode     String   @default("BUYER") // BUYER | SELLER

  // Timing & lifecycle — lifecycle: draft → queued → running → completed | failed
  startedAt      DateTime?
  completedAt    DateTime?
  failedAt       DateTime?
  errorMessage   String?   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  leads          ir_lead[]
}

// ─── LEADS ───
model ir_lead {
  id               String   @id @default(cuid())
  campaignId       String
  campaign         ir_campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  
  // Identity
  profileHandle    String?
  profileName      String?
  profileUrl       String?
  profilePlatform  String?  // youtube | reddit | instagram | linkedin | telegram | 99acres | etc
  avatarUrl        String?
  
  // Contact (optional, enriched)
  email            String?
  phone            String?
  linkedinUrl      String?
  
  // Source signal
  sourcePlatform   String   // where the signal was captured
  sourceUrl        String?  // link to the original post/comment/thread
  sourceContent    String   @db.Text // the actual comment/post text
  sourceType       String   // comment | post | review | listing | query | dm_request
  capturedAt       DateTime // when the signal was posted/detected
  
  // Scoring
  totalScore       Int      @default(0) // 0-100
  tier             String   @default("watching") // hot | warm | cool | watching
  
  // Dimension scores (0-100 each, weighted to total)
  scoreSpecificity       Int @default(0)
  scoreBudgetClarity     Int @default(0)
  scoreUrgency           Int @default(0)
  scoreEngagementVelocity Int @default(0)
  scoreDeveloperFollow   Int @default(0)
  scoreContentCreator    Int @default(0)
  scoreCrossPlatform     Int @default(0)
  scoreFinancialReady    Int @default(0)
  scoreLocationLock      Int @default(0)
  scoreProfileMatch      Int @default(0)
  
  // Inferred attributes
  inferredBuyerType    String?  // end_user | nri | investor | upgrade_buyer
  inferredBudget       String?  // e.g., "2-3 Cr"
  inferredLocation     String?  // e.g., "Indiranagar, Bangalore"
  inferredTimeline     String?  // e.g., "6 months"
  inferredIncome       String?  // e.g., "25-40 LPA"
  isNRI                Boolean  @default(false)
  nriCountry           String?
  
  // AI Insights
  aiInsightClaude      String?  @db.Text
  aiInsightGPT         String?  @db.Text
  aiRecommendedAction  String?  @db.Text
  aiResponseDraft      String?  @db.Text
  aiWhyStrong          String?  @db.Text
  
  // Behavioral patterns detected
  behavioralPatterns   String[] // life_event | peer_influence | vastu | comparison | proxy | complaint | fomo | depth
  velocityPattern      String?  // accelerating | burst | steady | decelerating | dormant
  
  // Engagement tracking
  engagementStatus     String   @default("new") // new | contacted | responded | site_visit | converted | lost
  notes                String?  @db.Text
  
  // Cross-platform signals
  crossPlatformSignals Json?    // [{platform, url, content, date}]

  // Intent mode — mirrors parent campaign
  intentMode           String   @default("BUYER") // BUYER | SELLER
  intentType           String?  // BUYER: buyer|investor|relocation | SELLER: owner|broker|developer
  listingPrice         String?  // SELLER mode: extracted listing price
  matchedSupply        Json?    // BUYER mode: shadow lead match {project, location, price}

  // Origin — real: scraped from live source | synthetic: AI-generated for demo/testing
  leadOriginType       String   @default("real") // real | synthetic

  // Freshness tracking
  firstSeenAt          DateTime @default(now())
  lastSeenAt           DateTime @default(now())
  freshnessScore       Float    @default(1.0)    // 1.0 = fresh today, decays over time

  // Probabilistic deduplication — uses safe cluster language, never claims certainty
  clusterId            String?                   // shared ID groups probable-duplicate signals
  duplicateProbability Float?                    // 0-1 matching confidence
  dedupeDecision       String?                   // distinct | possible_cluster | probable_duplicate | exact_duplicate
  matchReasons         String[]                  // human-readable reasons for the cluster decision

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([campaignId])
  @@index([tier])
  @@index([totalScore])
  @@index([sourcePlatform])
  @@index([leadOriginType])
  @@index([clusterId])
  @@unique([profileHandle, sourcePlatform, campaignId])
}

// ─── SIGNAL LOG ───
// Raw signals before processing - keeps audit trail
model ir_signal_log {
  id           String   @id @default(cuid())
  campaignId   String
  platform     String
  authorHandle String?
  authorName   String?
  content      String   @db.Text
  sourceUrl    String?
  rawData      Json?
  processed    Boolean  @default(false)
  leadId       String?  // linked after processing
  createdAt    DateTime @default(now())
  
  @@index([campaignId])
  @@index([processed])
}

// ─── SOURCE CHANNELS ───
// Configured channels/groups to monitor per platform
model ir_source_channel {
  id           String   @id @default(cuid())
  platform     String   // youtube | reddit | telegram | instagram | facebook
  channelId    String   // YouTube channel ID, subreddit name, Telegram group ID, etc.
  channelName  String
  channelUrl   String?
  city         String?  // which city this channel covers
  isActive     Boolean  @default(true)
  lastScraped  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@unique([platform, channelId])
}
